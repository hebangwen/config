#!/usr/bin/env python3
import struct
import argparse
import json
from typing import Dict, List, Any

# GGUF constants
GGUF_MAGIC = 0x46554747  # "GGUF" in little-endian
GGUF_VERSION = 3

# GGUF datatype
GGUF_DATA_TYPES = {
    0: 'F32',
    1: 'F16',
    2: 'Q4_0',
    3: 'Q4_1',
    6: 'Q5_0',
    7: 'Q5_1',
    8: 'Q8_0',
    9: 'Q8_1',
    10: 'Q2_K',
    11: 'Q3_K',
    12: 'Q4_K',
    13: 'Q5_K',
    14: 'Q6_K',
    15: 'Q8_K',
    16: 'IQ2_XXS',
    17: 'IQ2_XS',
    18: 'IQ3_XXS',
    19: 'IQ1_S',
    20: 'IQ4_NL',
    21: 'IQ3_S',
    22: 'IQ2_S',
    23: 'IQ4_XS',
    24: 'I8',
    25: 'I16',
    26: 'I32',
    27: 'I64',
    28: 'F64',
    29: 'IQ1_M',
    30: 'BF16',
    34: 'TQ1_0',
    35: 'TQ2_0',
    39: 'MXFP4',
}

def read_string(f) -> str:
    length = struct.unpack('<Q', f.read(8))[0]
    return f.read(length).decode('utf-8')

def read_gguf_header(f) -> Dict[str, Any]:
    magic, version = struct.unpack('<II', f.read(8))
    if magic != GGUF_MAGIC:
        raise ValueError("Invalid GGUF file !!!")
    if version != GGUF_VERSION:
        print(f"Warning: Unsupported GGUF version {version} (expected {GGUF_VERSION})")

    header = {
        'magic': magic,
        'version': version,
        'tensor_count': struct.unpack('<Q', f.read(8))[0],
        'kv_count': struct.unpack('<Q', f.read(8))[0],
    }
    return header

def read_kv_data(f, count: int) -> Dict[str, Any]:
    kv_data = {}
    for _ in range(count):
        key = read_string(f)
        value_type = struct.unpack('<I', f.read(4))[0]
        
        if value_type == 0:  # UINT8
            value = struct.unpack('<B', f.read(1))[0]
        elif value_type == 1:  # INT8
            value = struct.unpack('<b', f.read(1))[0]
        elif value_type == 2:  # UINT16
            value = struct.unpack('<H', f.read(2))[0]
        elif value_type == 3:  # INT16
            value = struct.unpack('<h', f.read(2))[0]
        elif value_type == 4:  # UINT32
            value = struct.unpack('<I', f.read(4))[0]
        elif value_type == 5:  # INT32
            value = struct.unpack('<i', f.read(4))[0]
        elif value_type == 6:  # FLOAT32
            value = struct.unpack('<f', f.read(4))[0]
        elif value_type == 7:  # BOOL
            value = bool(struct.unpack('<B', f.read(1))[0])
        elif value_type == 8:  # STRING
            value = read_string(f)
        elif value_type == 9:  # ARRAY
            array_type = struct.unpack('<I', f.read(4))[0]
            array_len = struct.unpack('<Q', f.read(8))[0]
            value = []
            for _ in range(array_len):
                if array_type == 0:  # UINT8
                    value.append(struct.unpack('<B', f.read(1))[0])
                elif array_type == 1:  # INT8
                    value.append(struct.unpack('<b', f.read(1))[0])
                elif array_type == 2:  # UINT16
                    value.append(struct.unpack('<H', f.read(2))[0])
                elif array_type == 3:  # INT16
                    value.append(struct.unpack('<h', f.read(2))[0])
                elif array_type == 4:  # UINT32
                    value.append(struct.unpack('<I', f.read(4))[0])
                elif array_type == 5:  # INT32
                    value.append(struct.unpack('<i', f.read(4))[0])
                elif array_type == 6:  # FLOAT32
                    value.append(struct.unpack('<f', f.read(4))[0])
                elif array_type == 7:  # BOOL
                    value.append(bool(struct.unpack('<B', f.read(1))[0]))
                elif array_type == 8:  # STRING
                    value.append(read_string(f))
        else:
            raise ValueError(f"unknown value type: {value_type}")
        
        kv_data[key] = value
    return kv_data

def read_tensors(f, count: int) -> List[Dict[str, Any]]:
    tensors = []
    for _ in range(count):
        name = read_string(f)
        n_dims = struct.unpack('<I', f.read(4))[0]
        dims = struct.unpack(f'<{n_dims}Q', f.read(8 * n_dims))
        dtype = struct.unpack('<I', f.read(4))[0]
        offset = struct.unpack('<Q', f.read(8))[0]
        
        tensors.append({
            'name': name,
            'n_dims': n_dims,
            'dims': dims,
            'dtype': GGUF_DATA_TYPES.get(dtype, f'UNKNOWN({dtype})'),
            'offset': offset,
        })
    return tensors

def format_value(value: Any, max_length: int = 80) -> str:
    if isinstance(value, str):
        if len(value) > max_length:
            return f'"{value[:max_length]}..." (length: {len(value)})'
        return f'"{value}"'
    elif isinstance(value, list):
        if not value:
            return "[]"
        
        elements = []
        total_len = 2
        for elem in value:
            elem_str = str(elem)
            if total_len + len(elem_str) + 2 > max_length:  # 2 for comma and space
                elements.append("...")
                break
            elements.append(elem_str)
            total_len += len(elem_str) + 2
        
        content = ", ".join(elements)
        if len(value) > len(elements):
            content += f" ... (total {len(value)})"
        return f"[{content}]"
    else:
        return str(value)

def ggufcat(filename: str, show_tensors: bool = True, 
           json_output: bool = False, max_length: int = 80):
    with open(filename, 'rb') as f:
        header = read_gguf_header(f)
        kv_data = read_kv_data(f, header['kv_count'])
        tensors = read_tensors(f, header['tensor_count'])
        
        if json_output:
            output = {
                'header': header,
                'metadata': kv_data,
                'tensors': tensors,
            }
            print(json.dumps(output, indent=2))
        else:
            print(f"GGUF      : {filename}")
            print(f"Version   : {header['version']}")
            print(f"# Tensor  : {header['tensor_count']}")
            print(f"# Metadata: {header['kv_count']}")
            
            print("\nMetadata:")
            for k, v in kv_data.items():
                formatted_value = format_value(v, max_length)
                print(f"  {k}: {formatted_value}")
            
            if show_tensors:
                print("\nTensor Information:")
                for tensor in tensors:
                    print(f"  {tensor['name']}: {tensor['dtype']} {tensor['dims']} @ {tensor['offset']}")

def main():
    parser = argparse.ArgumentParser(description='GGUF file watcher')
    parser.add_argument('filename', help='GGUF filepath')
    parser.add_argument('--no-tensors', action='store_false', dest='show_tensors',
                       help='no tensor info')
    parser.add_argument('--json', action='store_true',
                       help='print as json format')
    parser.add_argument('--max-length', type=int, default=80,
                       help='max length for metadata (default: 80)')
    args = parser.parse_args()
    
    ggufcat(args.filename, args.show_tensors, args.json, args.max_length)

if __name__ == '__main__':
    main()

